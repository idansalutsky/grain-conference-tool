# =============================================================================
# Grain Conference Tool — environment template
# =============================================================================
# EVERYTHING HERE IS OPTIONAL. The app boots and runs with this file empty (or
# absent). With no keys it degrades gracefully: it still seeds, serves
# conferences / scoring / planning / companies, captures leads through the
# Brain (deterministic extraction fallback), and runs the LangGraph brain with
# deterministic fallbacks for every step.
#
# You do NOT have to edit this file to add keys. The recommended way is the
# in-app UI: Settings -> Integrations. Keys saved there are stored in the
# database and OVERRIDE these env vars at runtime (no restart, no redeploy).
# Env vars are only a convenience for headless / CI hosting.
# -----------------------------------------------------------------------------

# --- AI gateway (OpenRouter) ----------------------------------------------
# One key unlocks all LLM features (lead extraction from voice/photo/text,
# briefs, conference discovery, brain reasoning). Without it those features
# fall back to deterministic logic. Free tier covers the full demo.
# Get one at https://openrouter.ai  ->  paste it in Settings -> Integrations.
OPENROUTER_API_KEY=

# Perplexity (grounded web search for discovery/briefs). Optional — OpenRouter
# already routes a Sonar model, so you usually do NOT need this separately.
PERPLEXITY_API_KEY=

# --- HubSpot (CRM push) ----------------------------------------------------
# Without a token, HubSpot push runs in DRY-RUN mode (shows what WOULD be sent,
# writes nothing). Add a Private App token to make pushes live.
HUBSPOT_PRIVATE_APP_TOKEN=

# --- Telegram (field-capture bot) -----------------------------------------
# Only needed if you want reps to capture leads by messaging a Telegram bot.
# Create one via @BotFather. Bot username has a sensible default.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=GrainSales_bot

# --- Admin gate ------------------------------------------------------------
# Guards deploy-time admin ops (registering the Telegram webhook). Only set it
# if you use the Telegram bot. Any long random string. Unset = those endpoints
# fail closed (503), which is safe.
ADMIN_API_KEY=

# Optional allowlist: if set, the Telegram webhook may only be pointed at this
# exact public origin (defence-in-depth). Leave unset to accept any https origin.
PUBLIC_BASE_URL=

# --- Defaults — change only if you know why -------------------------------
# Where the SQLite DB + audio live. In Docker this is the persisted volume.
DATA_DIR=./data
OPENROUTER_TEXT_MODEL=google/gemini-2.5-flash
OPENROUTER_AUDIO_MODEL=google/gemini-2.5-flash
OPENROUTER_SEARCH_MODEL=perplexity/sonar
LOG_LEVEL=INFO

# Force UTF-8 stdout. Needed on Windows consoles (cp1252) so seed scripts can
# print emoji without crashing. Already set inside the Docker image.
PYTHONIOENCODING=utf-8

# Lock down CORS in production: comma-separated exact origins (e.g.
# https://your-app.onrender.com). Defaults to "*" (fine for the single-origin
# deploy + local dev). Only needed for a split frontend/backend deploy.
CORS_ALLOW_ORIGINS=*
