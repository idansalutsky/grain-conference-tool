# Required: OpenRouter universal LLM gateway
# Get one at https://openrouter.ai (free tier covers the full demo)
OPENROUTER_API_KEY=

# Optional: only set if you want to use the Telegram bot field capture
# Create via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

# Optional: only set if you want HubSpot push to be live (otherwise dry-run)
HUBSPOT_PRIVATE_APP_TOKEN=

# Defaults — change only if you know why
DATA_DIR=./data
OPENROUTER_TEXT_MODEL=google/gemini-2.5-flash
OPENROUTER_AUDIO_MODEL=google/gemini-2.5-flash
OPENROUTER_SEARCH_MODEL=perplexity/sonar
LOG_LEVEL=INFO
